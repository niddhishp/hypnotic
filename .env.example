# ─── Hypnotic Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── AI Providers (at least ONE required for Insight + Manifest) ──────────────
# Recommended: use OpenRouter for a single key that covers all models
VITE_OPENROUTER_API_KEY=sk-or-...

# Direct provider keys (used as fallback)
# WARNING: These are exposed in the client bundle with Vite.
# For production, move AI calls to Supabase Edge Functions and use server-only keys.
VITE_OPENAI_API_KEY=sk-...
VITE_ANTHROPIC_API_KEY=sk-ant-...

# ─── Search Providers (at least ONE recommended for Insight research) ─────────
VITE_EXA_API_KEY=
VITE_SERPAPI_KEY=
VITE_BRAVE_SEARCH_API_KEY=

# ─── Craft Generation Models ──────────────────────────────────────────────────
VITE_FAL_API_KEY=
VITE_REPLICATE_API_TOKEN=
VITE_RUNWAY_API_KEY=
VITE_ELEVENLABS_API_KEY=
VITE_STABILITY_API_KEY=

# ─── Stripe (for billing) ────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# NOTE: STRIPE_SECRET_KEY must only be used server-side (Edge Function / Next.js API route)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_AGENCY=price_...

# ─── App ─────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5173
