                  <h3 className="serif" style={{ fontSize: '2rem', lineHeight: 1.1, color: 'var(--w)', marginBottom: 16, whiteSpace: 'pre-line' }}>{m.title}</h3>
                  <p style={{ fontSize: '.9375rem', lineHeight: 1.65, color: 'var(--w50)', marginBottom: 32 }}>{m.desc}</p>
                  <ul style={{ listStyle: 'none', display: 'flex', flexDirection: 'column', gap: 10 }}>
                    {m.features.map((f) => (
                      <li key={f} style={{ fontSize: '.8125rem', color: 'var(--w30)', display: 'flex', alignItems: 'flex-start', gap: 10, lineHeight: 1.5 }}>
                        <span style={{ color: 'var(--gold)', opacity: .6, flexShrink: 0, marginTop: 1, fontSize: '.73rem' }}>→</span>{f}
                      </li>
                    ))}
                  </ul>
                  {/* Glow */}
                  <div className="mod-glow" style={{ position: 'absolute', bottom: -60, right: -60, width: 200, height: 200, borderRadius: '50%', filter: 'blur(80px)', pointerEvents: 'none', opacity: .3 }} />
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── PIPELINE EXPLAINER ───────────────────────────────────────────── */}
        <section id="pipeline" style={{ padding: '120px 0', position: 'relative', zIndex: 1 }}>
          <div style={{ maxWidth: 1200, margin: '0 auto', padding: '0 48px' }}>
            <div className="fade-up">
              <div style={{ fontSize: '.7rem', fontWeight: 500, letterSpacing: '.2em', textTransform: 'uppercase', color: 'var(--gold)', opacity: .8, marginBottom: 16 }}>How it works</div>
              <h2 className="serif" style={{ fontSize: 'clamp(2rem,4vw,3.5rem)', lineHeight: 1.15, color: 'var(--w)', marginBottom: 16 }}>
                The creative pipeline,<br /><em style={{ fontStyle: 'italic', color: 'var(--gold)' }}>end to end.</em>
              </h2>
              <p style={{ fontSize: '1rem', lineHeight: 1.7, color: 'var(--w50)', maxWidth: 520 }}>
                Each stage passes its intelligence forward. By the time you reach Amplify, your content carries the full weight of everything that preceded it.
              </p>
            </div>

            <div className="fade-up" style={{ display: 'flex', alignItems: 'stretch', marginTop: 64, border: '1px solid var(--border)', borderRadius: 6, overflow: 'hidden' }}>
              {PIPELINE_COLS.map((c, i) => (
                <div key={c.label} style={{ flex: 1, padding: '40px 32px', borderRight: i < 3 ? '1px solid var(--border)' : 'none', position: 'relative' }}>
                  <div style={{ fontFamily: "'Courier Prime',monospace", fontSize: '.63rem', color: 'var(--w30)', letterSpacing: '.1em', marginBottom: 20 }}>{c.num}</div>
                  <div className={`serif ${c.labelClass}`} style={{ fontSize: '.7rem', fontWeight: 500, letterSpacing: '.18em', textTransform: 'uppercase', marginBottom: 16 }}>{c.label}</div>
                  <h4 className="serif" style={{ fontSize: '1.5rem', lineHeight: 1.2, marginBottom: 12, color: 'var(--w)' }}>{c.title}</h4>
                  <p style={{ fontSize: '.8125rem', lineHeight: 1.6, color: 'var(--w30)' }}>{c.body}</p>
                  {i < 3 && (
                    <div style={{ position: 'absolute', right: -1, top: '50%', transform: 'translateY(-50%)', width: 24, height: 24, background: 'var(--gold)', borderRadius: '50%', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '.6rem', color: '#08080A', fontWeight: 700, zIndex: 2 }}>→</div>
                  )}
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── HUMAN ENHANCEMENT ────────────────────────────────────────────── */}
        <section id="human" style={{ padding: '120px 0', background: 'var(--surf)', borderTop: '1px solid var(--border)', borderBottom: '1px solid var(--border)', position: 'relative', zIndex: 1 }}>
          <div style={{ maxWidth: 1200, margin: '0 auto', padding: '0 48px' }}>
            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 80, alignItems: 'center' }}>
              {/* Text */}
              <div className="fade-up">
                <div style={{ display: 'inline-flex', alignItems: 'center', gap: 8, padding: '8px 16px', borderRadius: 4, border: '1px solid rgba(201,169,110,.3)', background: 'var(--gold-d)', fontSize: '.72rem', fontWeight: 500, letterSpacing: '.08em', textTransform: 'uppercase', color: 'var(--gold)', marginBottom: 28 }}>
                  <span style={{ fontWeight: 700, fontSize: '1rem' }}>+</span> Human Enhancement
                </div>
                <h2 className="serif" style={{ fontSize: 'clamp(2rem,4vw,3rem)', lineHeight: 1.15, color: 'var(--w)', marginBottom: 16 }}>
                  AI does the work.<br /><em style={{ fontStyle: 'italic', color: 'var(--gold)' }}>Humans elevate it.</em>
                </h2>
                <p style={{ fontSize: '1rem', lineHeight: 1.7, color: 'var(--w50)', marginBottom: 36 }}>
                  At any stage, tap +Human to bring in a verified specialist — a brand strategist to interrogate your Insight report, a copywriter to sharpen your Manifest deck, a director to refine your Craft outputs.
                </p>
                <button onClick={() => navigate('/marketplace')} style={{ display: 'inline-flex', alignItems: 'center', gap: 10, padding: '14px 28px', borderRadius: 4, fontSize: '.8rem', fontWeight: 500, letterSpacing: '.06em', textTransform: 'uppercase', background: 'var(--gold)', color: '#08080A', border: 'none', cursor: 'pointer', transition: 'opacity .2s' }}
                  onMouseEnter={e => (e.currentTarget.style.opacity = '.85')}
                  onMouseLeave={e => (e.currentTarget.style.opacity = '1')}>
                  Browse experts →
                </button>
                {/* Skill tags */}
                <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: 8, marginTop: 36 }}>
                  {['Brand Strategy','Screenwriting','Art Direction','Performance Marketing','Audience Research','Motion Design','Media Planning','Copywriting'].map((s) => (
                    <div key={s} style={{ fontSize: '.72rem', color: 'var(--w30)', padding: '8px 12px', border: '1px solid var(--border)', borderRadius: 3, textAlign: 'center', transition: 'all .2s', cursor: 'default' }}
                      onMouseEnter={e => { e.currentTarget.style.borderColor = 'rgba(201,169,110,.3)'; e.currentTarget.style.color = 'var(--gold)'; }}
                      onMouseLeave={e => { e.currentTarget.style.borderColor = 'var(--border)'; e.currentTarget.style.color = 'var(--w30)'; }}>{s}</div>
                  ))}
                </div>
              </div>

              {/* Expert cards */}
              <div className="fade-up" style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>
                {EXPERTS.map((e) => (
                  <div key={e.name} style={{ display: 'flex', alignItems: 'center', gap: 16, padding: '16px 20px', background: 'var(--black)', border: '1px solid var(--border)', borderRadius: 6, transition: 'border-color .3s', cursor: 'default' }}
                    onMouseEnter={el => (el.currentTarget.style.borderColor = 'rgba(201,169,110,.3)')}
                    onMouseLeave={el => (el.currentTarget.style.borderColor = 'var(--border)')}>
                    <div style={{ width: 40, height: 40, borderRadius: '50%', background: 'var(--surf2)', border: '1px solid var(--border)', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '1.1rem', flexShrink: 0 }}>{e.emoji}</div>
                    <div style={{ flex: 1 }}>
                      <div style={{ fontSize: '.875rem', fontWeight: 500, color: 'var(--w)' }}>{e.name}</div>
                      <div style={{ fontSize: '.75rem', color: 'var(--w30)', marginTop: 2 }}>{e.role}</div>
                    </div>
                    <span className={`mod-tag ${e.moduleClass}`} style={{ fontSize: '.62rem', fontWeight: 500, letterSpacing: '.12em', textTransform: 'uppercase', padding: '4px 9px', borderRadius: 3, flexShrink: 0, border: '1px solid' }}>{e.module}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </section>

        {/* ── FEATURES GRID ────────────────────────────────────────────────── */}
        <section style={{ padding: '120px 0', position: 'relative', zIndex: 1 }}>
          <div style={{ maxWidth: 1200, margin: '0 auto', padding: '0 48px' }}>
            <div className="fade-up" style={{ marginBottom: 72 }}>
              <div style={{ fontSize: '.7rem', fontWeight: 500, letterSpacing: '.2em', textTransform: 'uppercase', color: 'var(--gold)', opacity: .8, marginBottom: 16 }}>Built Different</div>
              <h2 className="serif" style={{ fontSize: 'clamp(2rem,4vw,3.5rem)', lineHeight: 1.15, color: 'var(--w)' }}>
                Every decision<br /><em style={{ fontStyle: 'italic', color: 'var(--gold)' }}>engineered for production.</em>
              </h2>
            </div>

            <div className="fade-up" style={{ display: 'grid', gridTemplateColumns: 'repeat(3,1fr)', gap: 1, border: '1px solid var(--border)', borderRadius: 6, overflow: 'hidden' }}>
              {FEATURES.map((f, i) => (
                <div key={f.title} style={{ padding: '40px 32px', background: 'var(--surf)', borderRight: (i+1) % 3 !== 0 ? '1px solid var(--border)' : 'none', borderTop: i >= 3 ? '1px solid var(--border)' : 'none', transition: 'background .3s' }}
                  onMouseEnter={e => (e.currentTarget.style.background = 'var(--surf2)')}
                  onMouseLeave={e => (e.currentTarget.style.background = 'var(--surf)')}>
                  <div style={{ width: 40, height: 40, marginBottom: 20, display: 'flex', alignItems: 'center', justifyContent: 'center', border: '1px solid var(--border)', borderRadius: 6, fontSize: '1.1rem', background: 'var(--black)' }}>{f.icon}</div>
                  <h4 style={{ fontSize: '1rem', fontWeight: 500, color: 'var(--w)', marginBottom: 10 }}>{f.title}</h4>
                  <p style={{ fontSize: '.8125rem', lineHeight: 1.6, color: 'var(--w30)' }}>{f.body}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── PRICING ──────────────────────────────────────────────────────── */}
        <section id="pricing" style={{ padding: '120px 0', background: 'var(--surf)', borderTop: '1px solid var(--border)', borderBottom: '1px solid var(--border)', position: 'relative', zIndex: 1 }}>
          <div style={{ maxWidth: 1200, margin: '0 auto', padding: '0 48px' }}>
            <div className="fade-up" style={{ textAlign: 'center', marginBottom: 72 }}>
              <div style={{ fontSize: '.7rem', fontWeight: 500, letterSpacing: '.2em', textTransform: 'uppercase', color: 'var(--gold)', opacity: .8, marginBottom: 16 }}>Pricing</div>
              <h2 className="serif" style={{ fontSize: 'clamp(2rem,4vw,3.5rem)', lineHeight: 1.15, color: 'var(--w)', marginBottom: 16 }}>
                Start free.<br /><em style={{ fontStyle: 'italic', color: 'var(--gold)' }}>Scale when you're ready.</em>
              </h2>
              <p style={{ fontSize: '1rem', lineHeight: 1.7, color: 'var(--w50)', maxWidth: 420, margin: '0 auto' }}>14-day free trial on all plans. No credit card required to start.</p>
            </div>

            <div className="fade-up" style={{ display: 'grid', gridTemplateColumns: 'repeat(3,1fr)', gap: 2, border: '1px solid var(--border)', borderRadius: 8, overflow: 'hidden' }}>
              {PLANS.map((p, i) => (
                <div key={p.id} style={{ padding: '48px 40px', background: p.featured ? 'var(--surf2)' : 'var(--black)', position: 'relative', borderLeft: i > 0 ? (p.featured ? '1px solid rgba(201,169,110,.2)' : '1px solid var(--border)') : 'none', borderRight: p.featured ? '1px solid rgba(201,169,110,.2)' : 'none', transition: 'background .3s' }}
                  onMouseEnter={e => (e.currentTarget.style.background = p.featured ? '#181820' : '#0C0C0F')}
                  onMouseLeave={e => (e.currentTarget.style.background = p.featured ? 'var(--surf2)' : 'var(--black)')}>
                  {p.featured && (
                    <div style={{ position: 'absolute', top: -1, left: '50%', transform: 'translateX(-50%)', fontSize: '.58rem', letterSpacing: '.15em', fontWeight: 500, padding: '5px 16px', borderRadius: '0 0 4px 4px', background: 'var(--gold)', color: '#08080A', textTransform: 'uppercase', whiteSpace: 'nowrap' }}>Most Popular</div>
                  )}
                  <div style={{ fontSize: '.7rem', fontWeight: 500, letterSpacing: '.18em', textTransform: 'uppercase', color: 'var(--w30)', marginBottom: 20 }}>{p.tier}</div>
                  <div className="serif" style={{ fontSize: '3rem', color: 'var(--w)', lineHeight: 1, marginBottom: 4 }}>
                    <span style={{ fontSize: '1.5rem', verticalAlign: 'top', marginTop: 8, display: 'inline-block', fontFamily: "'DM Sans',sans-serif", fontWeight: 300 }}>$</span>
                    {p.price}
                    <span style={{ fontSize: '.875rem', color: 'var(--w50)', fontFamily: "'DM Sans',sans-serif", fontWeight: 300, verticalAlign: 'middle' }}>/mo</span>
                  </div>
                  <p style={{ fontSize: '.875rem', color: 'var(--w50)', marginBottom: 28, lineHeight: 1.5, marginTop: 8 }}>{p.desc}</p>
                  <div style={{ height: 1, background: 'var(--border)', marginBottom: 28 }} />
                  <ul style={{ listStyle: 'none', display: 'flex', flexDirection: 'column', gap: 12, marginBottom: 36 }}>
                    {p.features.map((f) => (
                      <li key={f} style={{ fontSize: '.8125rem', color: 'var(--w50)', display: 'flex', alignItems: 'flex-start', gap: 10, lineHeight: 1.4 }}>
                        <span style={{ color: 'var(--gold)', flexShrink: 0, fontSize: '.72rem', marginTop: 1 }}>✓</span>{f}
                      </li>
                    ))}
                    {p.disabled?.map((f) => (
                      <li key={f} style={{ fontSize: '.8125rem', color: 'var(--w30)', display: 'flex', alignItems: 'flex-start', gap: 10, lineHeight: 1.4, opacity: .4 }}>
                        <span style={{ color: 'var(--w30)', flexShrink: 0, fontSize: '.72rem', marginTop: 1 }}>—</span>{f}
                      </li>
                    ))}
                  </ul>
                  <button onClick={() => navigate('/signup')} style={{ display: 'block', width: '100%', padding: '13px 24px', borderRadius: 4, fontSize: '.78rem', fontWeight: 500, letterSpacing: '.06em', textTransform: 'uppercase', textAlign: 'center', cursor: 'pointer', transition: 'all .2s', border: p.featured ? 'none' : '1px solid var(--border)', background: p.featured ? 'var(--gold)' : 'transparent', color: p.featured ? '#08080A' : 'var(--w50)' }}
                    onMouseEnter={e => { if (p.featured) e.currentTarget.style.opacity = '.88'; else { e.currentTarget.style.borderColor = 'rgba(255,255,255,.2)'; e.currentTarget.style.color = 'var(--w)'; } }}
                    onMouseLeave={e => { if (p.featured) e.currentTarget.style.opacity = '1'; else { e.currentTarget.style.borderColor = 'var(--border)'; e.currentTarget.style.color = 'var(--w50)'; } }}>
                    {p.id === 'agency' ? 'Contact sales' : 'Start free trial'}
                  </button>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── TESTIMONIALS ─────────────────────────────────────────────────── */}
        <section style={{ padding: '120px 0', position: 'relative', zIndex: 1 }}>
          <div style={{ maxWidth: 1200, margin: '0 auto', padding: '0 48px' }}>
            <div className="fade-up" style={{ textAlign: 'center', marginBottom: 72 }}>
              <div style={{ fontSize: '.7rem', fontWeight: 500, letterSpacing: '.2em', textTransform: 'uppercase', color: 'var(--gold)', opacity: .8, marginBottom: 16 }}>From the Field</div>
              <h2 className="serif" style={{ fontSize: 'clamp(2rem,4vw,3rem)', lineHeight: 1.15, color: 'var(--w)' }}>
                Trusted by creatives<br /><em style={{ fontStyle: 'italic', color: 'var(--gold)' }}>who ship.</em>
              </h2>
            </div>

            <div className="fade-up" style={{ display: 'grid', gridTemplateColumns: 'repeat(3,1fr)', gap: 2, border: '1px solid var(--border)', borderRadius: 6, overflow: 'hidden' }}>
              {TESTIMONIALS.map((t, i) => (
                <div key={t.author} style={{ padding: '40px 36px', background: 'var(--surf)', borderRight: i < 2 ? '1px solid var(--border)' : 'none', transition: 'background .3s' }}
                  onMouseEnter={e => (e.currentTarget.style.background = 'var(--surf2)')}
                  onMouseLeave={e => (e.currentTarget.style.background = 'var(--surf)')}>
                  <p className="serif" style={{ fontSize: '1.1rem', lineHeight: 1.55, color: 'var(--w)', marginBottom: 28, fontStyle: 'italic' }}>"{t.quote}"</p>
                  <div style={{ display: 'flex', alignItems: 'center', gap: 14 }}>
                    <div style={{ width: 40, height: 40, borderRadius: '50%', background: 'var(--surf2)', border: '1px solid var(--border)', display: 'flex', alignItems: 'center', justifyContent: 'center', fontSize: '1.1rem' }}>{t.emoji}</div>
                    <div>
                      <div style={{ fontSize: '.875rem', fontWeight: 500, color: 'var(--w)' }}>{t.author}</div>
                      <div style={{ fontSize: '.75rem', color: 'var(--w30)', marginTop: 2 }}>{t.role}</div>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        {/* ── CTA ──────────────────────────────────────────────────────────── */}
        <section style={{ padding: '160px 48px', textAlign: 'center', position: 'relative', overflow: 'hidden', zIndex: 1 }}>
          {/* CTA glow */}
          <div style={{ position: 'absolute', top: '50%', left: '50%', transform: 'translate(-50%,-50%)', width: 800, height: 400, borderRadius: '50%', background: 'radial-gradient(ellipse, rgba(201,169,110,0.08) 0%, transparent 70%)', pointerEvents: 'none' }} />
          <div className="fade-up" style={{ position: 'relative', zIndex: 1 }}>
            <h2 className="serif" style={{ fontSize: 'clamp(2.5rem,6vw,5rem)', lineHeight: 1.05, color: 'var(--w)', marginBottom: 20 }}>
              Ready to create<br /><em style={{ fontStyle: 'italic', color: 'var(--gold)' }}>without limits?</em>
            </h2>
            <p style={{ fontSize: '1.0625rem', lineHeight: 1.65, color: 'var(--w50)', maxWidth: 480, margin: '0 auto 48px' }}>
              Join the creatives, strategists, and studios using Hypnotic to move faster, think deeper, and produce better work.
            </p>
            <div style={{ display: 'flex', gap: 16, justifyContent: 'center', flexWrap: 'wrap' }}>
              <button onClick={() => navigate('/signup')} style={{ display: 'inline-flex', alignItems: 'center', gap: 10, padding: '16px 40px', borderRadius: 4, fontSize: '.875rem', fontWeight: 500, letterSpacing: '.06em', textTransform: 'uppercase', background: 'var(--gold)', color: '#08080A', border: 'none', cursor: 'pointer', transition: 'all .2s' }}
                onMouseEnter={e => { e.currentTarget.style.opacity = '.88'; e.currentTarget.style.transform = 'translateY(-1px)'; }}
                onMouseLeave={e => { e.currentTarget.style.opacity = '1'; e.currentTarget.style.transform = 'none'; }}>
                Start creating free →
              </button>
              <button onClick={() => navigate('/login')} style={{ display: 'inline-flex', alignItems: 'center', gap: 10, padding: '16px 40px', borderRadius: 4, fontSize: '.875rem', fontWeight: 500, letterSpacing: '.06em', textTransform: 'uppercase', background: 'transparent', color: 'var(--w50)', border: '1px solid var(--border)', cursor: 'pointer', transition: 'all .2s' }}
                onMouseEnter={e => { e.currentTarget.style.color = 'var(--w)'; e.currentTarget.style.borderColor = 'rgba(255,255,255,.2)'; }}
                onMouseLeave={e => { e.currentTarget.style.color = 'var(--w50)'; e.currentTarget.style.borderColor = 'var(--border)'; }}>
                Sign in
              </button>
            </div>
            <p style={{ fontSize: '.72rem', color: 'var(--w30)', marginTop: 24, letterSpacing: '.04em' }}>14-day trial · No credit card required · Cancel anytime</p>
          </div>
        </section>

        {/* ── FOOTER ───────────────────────────────────────────────────────── */}
        <footer style={{ padding: '64px 48px 40px', borderTop: '1px solid var(--border)' }}>
          <div style={{ maxWidth: 1200, margin: '0 auto' }}>
            <div style={{ display: 'grid', gridTemplateColumns: '2fr 1fr 1fr 1fr', gap: 48, marginBottom: 64 }}>
              <div>
                <div className="serif" style={{ fontSize: '1.2rem', letterSpacing: '.15em', textTransform: 'uppercase', color: 'var(--w)', marginBottom: 16 }}>
                  Hypno<span style={{ color: 'var(--gold)' }}>·</span>tic
                </div>
                <p style={{ fontSize: '.8125rem', lineHeight: 1.6, color: 'var(--w30)', maxWidth: 240 }}>
                  AI Creative Operating System. From insight to impact.
                </p>
              </div>
              {[
                { heading: 'Platform',  links: ['Insight','Manifest','Craft','Amplify','Workspace'] },
                { heading: 'Company',   links: ['About','Blog','Careers','Security'] },
                { heading: 'Support',   links: ['Documentation','Status','Privacy','Terms'] },
              ].map((col) => (
                <div key={col.heading}>
                  <h4 style={{ fontSize: '.68rem', fontWeight: 500, letterSpacing: '.15em', textTransform: 'uppercase', color: 'var(--w50)', marginBottom: 20 }}>{col.heading}</h4>
                  <ul style={{ listStyle: 'none', display: 'flex', flexDirection: 'column', gap: 10 }}>
                    {col.links.map((link) => (
                      <li key={link}><a href="#" style={{ fontSize: '.8125rem', color: 'var(--w30)', transition: 'color .2s' }}
                        onMouseEnter={e => (e.currentTarget.style.color = 'var(--w)')}
                        onMouseLeave={e => (e.currentTarget.style.color = 'var(--w30)')}>{link}</a></li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', paddingTop: 32, borderTop: '1px solid var(--border)', fontSize: '.72rem', color: 'var(--w30)' }}>
              <span>© {new Date().getFullYear()} Hypnotic. All rights reserved.</span>
              <span>Built for creatives who ship.</span>
            </div>
          </div>
        </footer>

      </div>
    </>
  );
}
